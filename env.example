# Node Settings
ENVIRONMENT=<your setting>

# Project Constants
PROJECT_SLUG=<your setting>

# NestJS
PORT=<your setting>
JWT_SECRET=<your setting>
JWT_EXPIRES=<your setting>
REFRESH_TOKEN_SECRET=<your setting>
REFRESH_TOKEN_EXPIRES=<your setting>

# NextJS
# AUTH_* dipakai server-side (runtime). NEXT_PUBLIC_* dipakai client-side via runtime env.js
AUTH_SECRET=<your setting>
AUTH_URL=<your setting>
AUTH_TRUST_HOST=<your setting>
AUTH_API_URL=<your setting>
NEXT_PUBLIC_API_URL=<your setting>
NEXT_PUBLIC_WEBSOCKET_URL=<your setting>
NEXT_PUBLIC_IMAGE_PATH=<your setting>

# Prisma
DATABASE_URL=<your setting>
# SEED_USERS=true untuk bootstrap user default, false untuk menonaktifkan auto-seed di production
SEED_USERS=<true|false>

# Postgres
POSTGRES_USER=<your setting>
POSTGRES_PASSWORD=<your setting>
POSTGRES_DB=<your setting>
